#!/bin/sh

# V2Ray service control script for Keenetic (Entware)
#
# Manages the lifecycle of the V2Ray/Xray service.
# Supports start, stop, restart, and enable/disable for boot.

# Configuration
V2RAY_BIN="/opt/bin/xray"
V2RAY_CONFIG="/opt/etc/v2ray/config.json"
PID_FILE="/var/run/v2ray.pid"
LOG_FILE="/opt/var/log/v2ray/access.log"
ERROR_LOG_FILE="/opt/var/log/v2ray/error.log"

# Symlink for boot service
ENABLED_LINK="/opt/etc/init.d/S99v2ray"

# Ensure log directory exists
mkdir -p $(dirname $LOG_FILE) >/dev/null 2>&1
touch $LOG_FILE
touch $ERROR_LOG_FILE

start_service() {
    if [ ! -x "$V2RAY_BIN" ]; then
        echo "Error: $V2RAY_BIN not found or not executable."
        return 1
    fi

    if [ -f "$PID_FILE" ] && kill -0 $(cat "$PID_FILE") 2>/dev/null; then
        echo "V2Ray is already running."
        return 1
    fi

    echo "Starting V2Ray..."
    $V2RAY_BIN -config $V2RAY_CONFIG > $LOG_FILE 2> $ERROR_LOG_FILE &

    echo $! > $PID_FILE
    echo "V2Ray started."
}

stop_service() {
    if [ ! -f "$PID_FILE" ] || ! kill -0 $(cat "$PID_FILE") 2>/dev/null; then
        echo "V2Ray is not running."
        return 1
    fi

    echo "Stopping V2Ray..."
    kill $(cat "$PID_FILE")
    rm -f "$PID_FILE"
    echo "V2Ray stopped."
}

enable_service() {
    ln -s "$0" "$ENABLED_LINK" 2>/dev/null
    echo "V2Ray service enabled on boot."
}

disable_service() {
    rm -f "$ENABLED_LINK" 2>/dev/null
    echo "V2Ray service disabled on boot."
}


case "$1" in
    start)
        start_service
        ;;
    stop)
        stop_service
        ;;
    restart)
        stop_service
        sleep 1
        start_service
        ;;
    enable)
        enable_service
        ;;
    disable)
        disable_service
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|enable|disable}"
        exit 1
esac

exit 0